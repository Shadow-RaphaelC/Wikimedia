@model IEnumerable<Models.Media>

@if (Model.Count() != 0)
{
    foreach (var media in Model)
    {
        var owner = DAL.DB.Users.Get(int.Parse(media.OwnerId));
        string avatarUrl = owner != null ? owner.Avatar : "/App_Assets/Users/no_avatar.png";

        <div class="mediaLayout">
            <a href="/Medias/Details/@media.Id" title="Voir les détails de @media.Title" style="text-decoration:none; width:100% !important">

                <div style="position: relative;">
                    <div class="mediaThumbnail"
                         style="background-image:url('https://img.youtube.com/vi/@media.YoutubeId/mqdefault.jpg');">
                    </div>

                    <div class="UserSmallAvatar"
                         style="position: absolute; bottom: 6px; left: 6px; border: 2px solid white;
                                background-image: url('@avatarUrl');">
                    </div>
                </div>
            </a>

            <div style="display: flex; align-items: center; justify-content: space-between; margin-left: 4px; margin-right: 4px;">
                <div class="ellipsis" style="font-size: 0.8em; font-weight: bold">
                    @media.Title
                </div>
                
                @if (media.OwnerId == Models.User.ConnectedUser.Id.ToString())
                {
                    if (media.Shared)
                    {
                        <i class="fa fa-share-alt" title="Partagé" style="color: dodgerblue; margin-right: 4px;"></i>
                    }
                    else
                    {
                        <i class="fa fa-lock" title="Non partagé" style="color: #aaa; margin-right: 4px;"></i>
                    }
                }
            </div>
            <div style="margin-left: 4px; color: gray; font-size: 0.65em">@media.Category <br /> @Helper.When(media.PublishDate)</div>
        </div>
    }
}
else
{
    <h3>Aucun résulat</h3>
}